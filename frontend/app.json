{
  "expo": {
    "name": "Endura",
    "slug": "endura",
    "version": "1.0.6",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#B5CFB7"
    },
    "notification": {
      "icon": "./assets/icon.png",
      "color": "#5E7F6E",
      "androidMode": "default",
      "androidCollapsedTitle": "Endura"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.endura.study",
      "buildNumber": "36",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Endura uses your camera so you can take a profile photo or attach a screenshot when sending feedback to the team.",
        "NSPhotoLibraryUsageDescription": "Endura accesses your photo library so you can choose a profile picture and attach screenshots when sending feedback to help us reproduce issues. Selected images are uploaded only when you save the change or submit the form.",
        "UIBackgroundModes": ["remote-notification"],
        "UISupportedInterfaceOrientations~ipad": [
          "UIInterfaceOrientationPortrait",
          "UIInterfaceOrientationPortraitUpsideDown",
          "UIInterfaceOrientationLandscapeLeft",
          "UIInterfaceOrientationLandscapeRight"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#B5CFB7"
      },
      "package": "com.endura.study",
      "versionCode": 17
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "owner": "phaedrus75",
    "extra": {
      "eas": {
        "projectId": "5fd638be-4053-4859-b3f4-b4b333d42c66"
      },
      "sentryDsn": "https://c4e763aceb5ded8115e4496763f50e67@o4511264215597056.ingest.de.sentry.io/4511264250200144"
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      "expo-web-browser",
      "expo-localization",
      "expo-font",
      "expo-apple-authentication",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#5E7F6E",
          "defaultChannel": "default",
          "sounds": []
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "organization": "endura-m2",
          "project": "endura-mobile",
          "url": "https://sentry.io/"
        }
      ],
      "@sentry/react-native"
    ]
  }
}
